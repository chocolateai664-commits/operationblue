# =============================================================================
# Operation Blue – environment template
# Copy to `.env` (local) or paste the same keys into Vercel → Settings → Env Vars.
# Only VITE_* vars reach the browser; provider keys live in Supabase secrets.
# =============================================================================

# ---- Required (client) -----------------------------------------------------
VITE_SUPABASE_PROJECT_ID="iuqrxursqqqicylynxph"
VITE_SUPABASE_URL="https://iuqrxursqqqicylynxph.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi...replace-with-anon-publishable-key..."

# ---- Smoke test only (NEVER ship to the browser) ---------------------------
# Used by `scripts/smoke-chat.mjs`. Generate a Supabase user access token
# (e.g. via `supabase auth sign-in` or grab it from devtools after logging in).
SMOKE_TEST_TOKEN=""
SMOKE_TEST_URL="http://localhost:8080"          # or your Vercel URL

# ---- Supabase Edge Function secrets (set via `supabase secrets set`) -------
# Do NOT put these in this file. Listed here only so you know what to configure:
#   LOVABLE_API_KEY=         # optional – Lovable AI Gateway
#   OPENAI_API_KEY=          # optional – direct OpenAI fallback
#   GEMINI_API_KEY=          # optional – direct Gemini fallback
#   STRIPE_SECRET_KEY=       # required for billing
